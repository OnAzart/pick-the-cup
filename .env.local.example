# Auto-injected by Vercel when you connect a Postgres storage integration
# (Storage tab -> Create Database -> Postgres). Do not set manually in production.
POSTGRES_URL=

# Free API key from https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# Random secret (e.g. `openssl rand -hex 32`). Vercel auto-sends this as
# `Authorization: Bearer $CRON_SECRET` to your Cron Job invocations once set.
CRON_SECRET=

# API key from https://resend.com — powers sponsor-inquiry and
# bracket-saved confirmation emails. Emails are skipped silently if unset.
RESEND_API_KEY=

# Optional: sender address once a domain is verified in Resend. Falls back
# to the shared sandbox sender (onboarding@resend.dev), which can only
# deliver to your own Resend account email.
RESEND_FROM_EMAIL=

# Optional: where new sponsor inquiries get emailed. If unset, inquiries
# are still stored in Postgres but no notification email is sent.
SPONSOR_NOTIFY_EMAIL=

# Canonical production origin used for all SEO (metadata, canonical URLs,
# sitemap, robots, structured data). No trailing slash. Defaults to
# https://pick-the-cup.vercel.app when unset. Set to your real domain
# (e.g. https://pickthecup.com) to switch everything over in one place.
NEXT_PUBLIC_SITE_URL=

# Optional: Google Search Console verification token. Paste the value from
# the "HTML tag" verification method (the content="..." part) to render the
# verification <meta> tag and claim the property.
GOOGLE_SITE_VERIFICATION=
